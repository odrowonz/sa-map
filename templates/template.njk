{# data[field_key] — объект { title, body, attachments } или [] таких, или string[] (поля *Path) с путями к схемам. Форматирование MD — здесь, не в data. #}
{%- macro md_record(r) -%}
{%- if r.title | default('') | trim or r.body | default('') | trim or (r.attachments and r.attachments.length) -%}
{%- if r.title | default('') | trim -%}**{{ r.title | trim }}**{%- if r.body | default('') | trim -%}

{{ r.body }}{% endif -%}
{%- elif r.body | default('') | trim -%}
{{ r.body }}{% endif -%}
{%- for a in r.attachments or [] -%}
{%- if a | is_image_att %}

![{{ a.original_name | default("file") | replace("[", "") | replace("]", "") | replace("\\", "") }}]({{ a.zip_path }})
{%- else %}

- {{ a | md_file_icon }}[{{ a.original_name | default("file") | replace("[", "") | replace("]", "") }}]({{ a.zip_path }})
{%- endif -%}
{%- endfor -%}
{%- endif -%}
{%- endmacro -%}

# Техническое задание: {{ project.name | default("Системный анализ") }}
*Дата генерации: {{ metadata.export_date }}*
{%- for lvl_conf in metadata.levels_config %}
{% set lvl_id = "L" + lvl_conf.n %}
<details>
<summary><strong>LEVEL {{ lvl_conf.n }} — {{ lvl_conf.title }}</strong></summary>

*{{ lvl_conf.q }}*
{%- for field in lvl_conf.fields %}
{% set field_key = lvl_id + "_" + field.name %}
{% set field_value = data[field_key] %}
{%- if field_value %}

### {{ field.label | default(field.name) }}
{%- if field.isArray and "Path" in field.name %}
{%- for x in field_value %}
{%- if x | is_string %}
![Схема ({{ field.label | default(field.name) }})]({{ x }})
{%- else %}
{{ md_record(x) }}
{%- if not loop.last %}{{ "\n" }}{% endif %}
{%- endif %}
{%- endfor %}
{%- elif field.isArray %}
{%- for item in field_value %}


{{ md_record(item) }}{% if not loop.last %}


{% endif -%}
{%- endfor %}
{%- else %}
{{ md_record(field_value) }}
{%- endif %}
{%- endif %}
{%- endfor %}
</details>
{% endfor %}
